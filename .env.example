# =============================================================================
# sales-agent-lab environment configuration
# Copy this file to .env and fill in the values Kenny provides.
# =============================================================================

# ---------------------------------------------------------------------------
# LLM configuration (OpenAI-compatible / Ollama)
# ---------------------------------------------------------------------------
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
# Default model for dev. Use qwen3.5:9b locally; append :cloud for cloud alias.
LLM_DEFAULT_MODEL=qwen3.5:9b
LLM_TEMPERATURE=0.5
LLM_MAX_TOKENS=2048
# Optional: faster model for quick classification/summaries
LLM_FAST_MODEL=qwen3.5:9b

# ---------------------------------------------------------------------------
# Kundenportal configuration
# ---------------------------------------------------------------------------
# Base URL of the deployed Kundenportal instance (no trailing slash)
KUNDENPORTAL_BASE_URL=https://webton-kundenportal.vercel.app
# Service token for service-to-service AIO calls (Kenny provides)
KUNDENPORTAL_SERVICE_TOKEN=
# Internal tenant used for Tectara / Webton admin testing
KUNDENPORTAL_TENANT_ID=92b2f6a6-5e56-4592-8dee-ff4cbfd53c81

# ---------------------------------------------------------------------------
# MailOps configuration
# ---------------------------------------------------------------------------
# Base URL of the MailOps service (no trailing slash)
MAILOPS_BASE_URL=http://localhost:3101
# Service token for MailOps calls (Kenny provides)
MAILOPS_SERVICE_TOKEN=

# ---------------------------------------------------------------------------
# Agent runtime configuration
# ---------------------------------------------------------------------------
# How often the outbound polling loop runs (in minutes)
AGENT_POLL_INTERVAL_MINUTES=5
# Minimum lead quality score (0-10) before the agent will draft outreach
AGENT_MIN_QUALITY_SCORE=7.0
# Default sender name and reply-to for outbound emails
AGENT_SENDER_NAME=Tectara Systems
AGENT_REPLY_TO=hello@tectara.io

# ---------------------------------------------------------------------------
# Webhook server configuration
# ---------------------------------------------------------------------------
# Host/port for the inbound webhook server (Kundenportal / MailOps -> agent)
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
# Optional secret to verify incoming webhook signatures (leave empty to skip)
WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Voice / future configuration (M4)
# ---------------------------------------------------------------------------
# Enable voice channel (M4). Keep false for M0-M3.
VOICE_ENABLED=false
# VOICE_STT_PROVIDER=deepgram
# VOICE_TTS_PROVIDER=elevenlabs
# VOICE_TELEPHONY_PROVIDER=twilio
